generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  email    String @unique
  password String
}

model Chat {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String 
  messages  Json
  createdAt DateTime @default(now())
}